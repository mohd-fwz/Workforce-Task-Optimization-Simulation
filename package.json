{
  "name": "workforce-optimizer",
  "version": "1.0.0",
  "description": "NGO Workforce & Task Optimization Dashboard",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev --workspace=@workforce/backend",
    "dev:frontend": "npm run dev --workspace=@workforce/frontend",
    "build": "npm run build --workspaces",
    "install:all": "npm install && npm install --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
